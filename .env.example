# Copy this to .env for local use, or set these in Render.

# Admin panel password (CHANGE THIS before deploying!)
ADMIN_PASSWORD=change-me-please

# Secret key for auth cookies — use any long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Database URL (Render Postgres or any Postgres instance)
# Example local value: postgres://postgres:postgres@localhost:5432/cricket_scorer
DATABASE_URL=

# Port is set automatically by Render
# PORT=3000
